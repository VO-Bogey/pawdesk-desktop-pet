  <ItemGroup>
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.20.1" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\Models\silueta.onnx" />
  </ItemGroup>

</Project>
