<Window x:Class="PawDesk.App.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PawDesk"
        Width="220"
        Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseWheel="Window_MouseWheel"
        Closing="Window_Closing">
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="更换图片" Click="ChangeImage_Click"/>
            <Separator/>
            <MenuItem Header="放大" Click="ZoomIn_Click"/>
            <MenuItem Header="缩小" Click="ZoomOut_Click"/>
            <MenuItem Header="恢复默认大小" Click="ResetScale_Click"/>
            <Separator/>
            <MenuItem x:Name="AnimationMenuItem"
                      Header="动画"
                      IsCheckable="True"
                      Click="Animation_Click"/>
            <MenuItem x:Name="TopmostMenuItem"
                      Header="始终置顶"
                      IsCheckable="True"
                      Click="Topmost_Click"/>
            <MenuItem x:Name="StartupMenuItem"
                      Header="开机启动"
                      IsCheckable="True"
                      Click="Startup_Click"/>
            <Separator/>
            <MenuItem Header="设置" Click="Settings_Click"/>
            <MenuItem Header="隐藏宠物" Click="Hide_Click"/>
            <MenuItem Header="退出" Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Background="Transparent">
        <Viewbox x:Name="PetRoot"
                 Width="220"
                 Height="220"
                 RenderTransformOrigin="0.5,0.72"
                 Cursor="Hand">
            <Viewbox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BreathScale" ScaleX="1" ScaleY="1"/>
                    <RotateTransform x:Name="SwayRotate" Angle="0"/>
                    <RotateTransform x:Name="LeanRotate" Angle="0"/>
                    <TranslateTransform x:Name="ReactionTranslate" X="0" Y="0"/>
                    <TranslateTransform x:Name="BounceTranslate" X="0" Y="0"/>
                </TransformGroup>
            </Viewbox.RenderTransform>

            <Grid Width="220" Height="220">
                <Image x:Name="PetImage"
                       Width="220"
                       Height="220"
                       Stretch="None"
                       Visibility="Collapsed"/>

                <Canvas x:Name="DefaultPet" Width="220" Height="220">
                    <Canvas x:Name="DefaultHead"
                            Width="220"
                            Height="220"
                            RenderTransformOrigin="0.5,0.72">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <RotateTransform x:Name="HeadRotate" Angle="0"/>
                                <TranslateTransform x:Name="HeadTranslate" X="0" Y="0"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>

                        <Ellipse Width="58" Height="74" Fill="#FFF6D7A8" Stroke="#FF4B3429" StrokeThickness="5" Canvas.Left="34" Canvas.Top="42" RenderTransformOrigin="0.5,0.95">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="-18"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="58" Height="74" Fill="#FFF6D7A8" Stroke="#FF4B3429" StrokeThickness="5" Canvas.Left="128" Canvas.Top="42" RenderTransformOrigin="0.5,0.95">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="18"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse Width="126" Height="118" Fill="#FFFFE2B8" Stroke="#FF4B3429" StrokeThickness="5" Canvas.Left="47" Canvas.Top="62"/>
                        <Ellipse Width="28" Height="34" Fill="#FF70452F" Canvas.Left="67" Canvas.Top="96"/>
                        <Ellipse Width="28" Height="34" Fill="#FF70452F" Canvas.Left="125" Canvas.Top="96"/>
                        <Ellipse Width="30" Height="22" Fill="#FF2A1A16" Canvas.Left="95" Canvas.Top="126"/>
                        <Path Stroke="#FF2A1A16" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 110 145 C 103 156, 91 158, 84 150"/>
                        <Path Stroke="#FF2A1A16" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M 110 145 C 117 156, 129 158, 136 150"/>
                        <Ellipse Width="8" Height="8" Fill="#FFFFFFFF" Canvas.Left="76" Canvas.Top="105"/>
                        <Ellipse Width="8" Height="8" Fill="#FFFFFFFF" Canvas.Left="134" Canvas.Top="105"/>
                    </Canvas>
                </Canvas>
            </Grid>
        </Viewbox>
    </Grid>
</Window>
